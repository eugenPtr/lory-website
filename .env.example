# Neon Postgres connection string (any Postgres works). PRD §3 / §11.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Payload secret — random string used to sign tokens.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Vercel Blob token for persistent media. Optional locally:
# if unset, uploads fall back to local disk (./media). PRD §3 / §11.
BLOB_READ_WRITE_TOKEN=
